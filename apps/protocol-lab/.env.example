# =============================================================================
# Agent Communication Protocol Playground — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# See ACCOUNT-SETUP.md for detailed setup instructions.
# =============================================================================

# -----------------------------------------------------------------------------
# AUTH (Optional — only needed for public deployment)
# -----------------------------------------------------------------------------
# Set AUTH_ENABLED=true to require JWT tokens on all API endpoints.
# When not set or false, all endpoints are open (dev mode).
AUTH_ENABLED=false
SUPABASE_JWT_SECRET=

# -----------------------------------------------------------------------------
# STRIPE — Fiat Payment Provider
# Required for: stripe-fiat payment provider
# Get keys at: https://dashboard.stripe.com/test/apikeys
# Cost: Free (test mode)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...  # Optional, frontend-only
# STRIPE_WEBHOOK_SECRET=whsec_...     # Optional, for webhook verification

# -----------------------------------------------------------------------------
# COINBASE DEVELOPER PLATFORM — Wallet + x402 Payment
# Required for: coinbase-cdp wallet provider, x402-usdc payment provider
# Get keys at: https://portal.cdp.coinbase.com
# Cost: Free (Base Sepolia testnet)
# -----------------------------------------------------------------------------
CDP_API_KEY_ID=
CDP_API_KEY_PRIVATE_KEY=
CDP_WALLET_NETWORK=base-sepolia

# -----------------------------------------------------------------------------
# LIGHTNING NETWORK — L402 Payment
# Required for: lightning-l402 payment provider
# Setup: Voltage Cloud (https://voltage.cloud) or Polar (https://lightningpolar.com)
# Cost: Free (testnet)
# -----------------------------------------------------------------------------
LIGHTNING_LND_REST_URL=
LIGHTNING_LND_MACAROON=
# LIGHTNING_LND_TLS_CERT=             # Only needed for local/self-signed certs
LIGHTNING_NETWORK=testnet

# -----------------------------------------------------------------------------
# OPENTELEMETRY — Observability
# Required for: opentelemetry observability provider
# Default: Jaeger at localhost:4318 (run: docker run -d -p 16686:16686 -p 4318:4318 jaegertracing/all-in-one:latest)
# Alternative: Honeycomb (https://honeycomb.io, free tier 20M events/month)
# -----------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=agent-communication
# For Honeycomb: OTEL_EXPORTER_OTLP_HEADERS=x-honeycomb-team=<api-key>

# -----------------------------------------------------------------------------
# NO ACCOUNT NEEDED — These providers use Node.js crypto
# -----------------------------------------------------------------------------
# did identity: Ed25519 keypairs generated locally
# x509 identity: RSA-2048 self-signed certificates
# oauth-jwt identity: RS256 JWT signing/verification
# envelope encryption: AES-256-GCM + ECDH
# tls-mutual encryption: RSA + AES-256-GCM hybrid
# All resilience providers: pure logic (retry, circuit-breaker, bulkhead)
# All transport providers: HTTP/WebSocket/gRPC (connect to running services)
