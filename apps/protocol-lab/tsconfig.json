{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "declaration": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noImplicitReturns": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@agent-communication/shared-protocols": ["packages/shared-protocols/src"],
      "@agent-communication/shared-types": ["packages/shared-types/src"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
