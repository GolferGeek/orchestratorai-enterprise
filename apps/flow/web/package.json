    "ionicons": "^7.0.0",
    "pinia": "^2.1.7",
    "vue": "^3.4.0",
    "vue-draggable-plus": "^0.6.1",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@pinia/testing": "^0.1.3",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/eslint-config-typescript": "^13.0.0",
    "@vue/test-utils": "^2.3.0",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.0.0",
    "jsdom": "^22.1.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^0.34.6",
    "vue-tsc": "^2.0.0"
  }
