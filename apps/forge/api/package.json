{
  "name": "@orchestratorai/forge-api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:dev:azure": "ENV_PROFILE=azure nest start --watch",
    "start:dev:gcp": "ENV_PROFILE=gcp nest start --watch",
    "start:dev:external": "nest start --watch -- --enable-external-agents",
    "start:dev:full": "./start-dev.sh",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint --ignore-pattern \"testing/**\" --ignore-pattern \"scripts/**\" --ignore-pattern \"dist/**\" --ignore-pattern \"supabase/scripts/**\" --ignore-pattern \"supabase/archive/**\" --ignore-pattern \"**/__tests__/integration/**\" .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./testing/test/jest-e2e.json",
    "test:e2e:user-management": "jest --config ./testing/test/jest-e2e.json user-management.e2e-spec",
    "agents:smoke": "API_BASE=http://localhost:6100 node ../../scripts/agents/smoke-validate-seeds.mjs",
    "agents:seed:blog": "bash ../../scripts/agents/seed-agent.sh ../../docs/feature/matt/payloads/blog_post_writer.json",
    "agents:seed:hr": "bash ../../scripts/agents/seed-agent.sh ../../docs/feature/matt/payloads/hr_assistant.json",
    "db:restore": "cd supabase/scripts && ./restore-database.sh",
    "db:post-restore": "cd supabase/scripts && ./post-restore-fix.sh",
    "db:verify": "cd supabase/scripts && ./verify-data.sh",
    "db:fix-all": "cd supabase/scripts && ./post-restore-fix.sh && ./verify-data.sh",
    "validate-models": "npx ts-node scripts/validate-models.ts",
    "validate-models:local": "npx ts-node scripts/validate-models.ts --local-only",
    "validate-models:dry-run": "npx ts-node scripts/validate-models.ts --dry-run",
    "smoke:media-storage": "npx ts-node -r tsconfig-paths/register scripts/smoke-media-storage-provider.ts",
    "bootstrap:media-bucket": "npx ts-node scripts/ensure-media-bucket.ts",
    "bootstrap:sqlserver-pilot-schema": "npx ts-node scripts/bootstrap-sqlserver-pilot-schema.ts",
    "smoke:data-pilot-db-provider": "npx ts-node -r tsconfig-paths/register scripts/smoke-database-provider-pilot.ts",
    "smoke:work-task-sink": "npx ts-node -r tsconfig-paths/register scripts/smoke-work-task-sink.ts",
    "smoke:work-routing-matrix": "npx ts-node scripts/smoke-work-routing-matrix.ts",
    "smoke:ado-env": "npx ts-node scripts/smoke-ado-env.ts",
    "smoke:slack-env": "npx ts-node scripts/smoke-slack-env.ts",
    "init:validate-manifest": "npx ts-node scripts/validate-seed-manifest.ts",
    "init:verify": "npx ts-node scripts/verify-init-data.ts",
    "init:bootstrap": "bash scripts/unified-seed.sh",
    "init:verify-schema": "npx ts-node scripts/verify-schema-portability.ts",
    "smoke:sqlserver-dual-path": "npx ts-node scripts/smoke-sqlserver-dual-path.ts",
    "bootstrap:sqlserver-full-schema": "npx ts-node scripts/bootstrap-sqlserver-full-schema.ts",
    "seed:sqlserver-agents": "npx ts-node scripts/seed-sqlserver-agents.ts",
    "audit:legal-showcase": "npx ts-node scripts/audit-legal-showcase.ts",
    "audit:legal-showcase:strict": "npx ts-node scripts/audit-legal-showcase.ts --strict-video"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
