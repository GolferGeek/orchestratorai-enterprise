    "@langchain/google-genai": "^2.1.25",
    "@langchain/langgraph": "^1.2.2",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.1",
    "@langchain/ollama": "^1.2.6",
    "@langchain/openai": "^1.2.13",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.17",
