    "@supabase/supabase-js": "^2.57.0",
    "@types/fs-extra": "^11.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/multer": "^2.0.0",
    "@types/uuid": "^10.0.0",
    "axios": "^1.9.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "docx": "^9.6.1",
    "dotenv": "^17.2.0",
    "google-auth-library": "^10.5.0",
    "jose": "^5.10.0",
    "js-tiktoken": "^1.0.21",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.11.0",
    "marked": "^15.0.12",
    "minimatch": "^10.2.4",
    "mssql": "^11.0.1",
    "openai": "^5.1.1",
    "opencascade.js": "2.0.0-beta.b5ff984",
    "pdf-parse": "^2.4.5",
    "pg": "^8.16.3",
    "prom-client": "^15.1.3",
    "quick-lru": "^5.1.1",
    "reflect-metadata": "^0.2.2",
    "rss-parser": "^3.13.0",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.25",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.17",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@types/eventsource": "^1.1.15",
    "@types/express": "^5.0.0",
    "@types/glob": "^8.1.0",
    "@types/jest": "^29.5.14",
    "@types/mssql": "^9.1.9",
    "@types/node": "^22.10.7",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.15.6",
    "@types/supertest": "^6.0.2",
    "ajv": "^8.17.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "eventsource": "^4.1.0",
    "globals": "^15.14.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
