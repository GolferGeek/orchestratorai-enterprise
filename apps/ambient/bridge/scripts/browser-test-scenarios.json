      "steps": [
        {"action": "navigate", "url": "http://localhost:4010/"},
        {"action": "click", "text": "Protocol stack"},
        {"action": "verify_text", "contains": ["identity: did"]}
      ],
      "validations": ["Identity provider shows did", "Test returns did:key:z6Mk... format"]
    },
    {
      "id": 7,
