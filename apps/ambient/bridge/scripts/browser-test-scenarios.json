{
  "name": "Agent Communication — Full Capability Browser Tests",
  "description": "34 scenarios covering every capability. Run via Claude Code Chrome automation.",
  "prerequisites": {
    "mainApi": "http://localhost:6100/health",
    "protocolApi": "http://localhost:4000/health",
    "researchHub": "http://localhost:4001/health",
    "marketPulse": "http://localhost:4002/health",
    "contentForge": "http://localhost:4003/health",
    "frontend": "http://localhost:4010"
  },
  "credentials": {
    "email": "golfergeek@orchestratorai.io",
    "password": "GolferGeek123!"
  },
  "scenarios": [
    {
      "id": 1,
      "name": "Authentication — Real JWT Login",
      "steps": [
        {"action": "navigate", "url": "http://localhost:4010/", "expect": "redirect to /login"},
        {"action": "fill", "selector": "input[type=email]", "value": "golfergeek@orchestratorai.io"},
        {"action": "fill", "selector": "input[type=password]", "value": "GolferGeek123!"},
        {"action": "click", "selector": "button[type=submit]"},
        {"action": "wait", "seconds": 2},
        {"action": "verify_url", "contains": "/", "not_contains": "/login"},
        {"action": "verify_js", "script": "localStorage.getItem('agent-comm-jwt')?.length > 100", "expect": true},
        {"action": "verify_js", "script": "JSON.parse(localStorage.getItem('agent-comm-user')).email", "expect": "golfergeek@orchestratorai.io"}
      ],
      "validations": ["JWT in localStorage", "User decoded from JWT", "Redirect to home"]
    },
    {
      "id": 2,
      "name": "Agent Discovery — Overview Page",
      "steps": [
        {"action": "navigate", "url": "http://localhost:4010/"},
        {"action": "verify_text", "contains": ["ResearchHub", "MarketPulse", "ContentForge"]},
        {"action": "verify_text", "contains": ["online", "v0.1.0"]},
        {"action": "verify_text", "contains": ["Trusted", "interactions"]}
      ],
      "validations": ["3 agents visible", "Trust scores displayed", "Heartbeat times shown"]
    },
    {
      "id": 3,
      "name": "Agent Discovery — Agent Cards via Browser",
      "steps": [
        {"action": "navigate", "url": "http://localhost:4010/apps/agent-consumer"},
        {"action": "fill", "selector": "input[type=text]", "value": "http://localhost:4001/.well-known/agent.json"},
        {"action": "click", "text": "Go"},
        {"action": "verify_text", "contains": ["ResearchHub", "capabilities", "version"]}
      ],
      "validations": ["Agent card JSON rendered", "Capabilities listed", "Clickable URLs in JSON"]
    },
    {
      "id": 4,
      "name": "Protocol Stack — All 12 Layers Visible",
      "steps": [
        {"action": "navigate", "url": "http://localhost:4010/"},
        {"action": "verify_text", "contains": ["12 layers"]},
        {"action": "click", "text": "Protocol stack"},
        {"action": "verify_text", "contains": ["discovery", "transport", "negotiation", "identity", "payment", "wallet", "trust", "encryption", "resilience", "observability", "orchestration", "audit"]}
      ],
      "validations": ["All 12 layer names visible", "Current provider for each layer shown"]
    },
    {
      "id": 5,
      "name": "Identity — Local Keys (Ed25519)",
      "api_setup": [
        {"method": "PUT", "url": "http://localhost:4000/api/protocol/config", "body": {"identity": "local-keys"}},
        {"method": "POST", "url": "http://localhost:4000/api/protocol/test/identity"}
      ],
      "steps": [
        {"action": "navigate", "url": "http://localhost:4010/"},
        {"action": "click", "text": "Protocol stack"},
        {"action": "verify_text", "contains": ["identity: local-keys"]}
      ],
      "validations": ["Identity provider shows local-keys", "Test returns Ed25519 key"]
    },
    {
      "id": 6,
      "name": "Identity — DID (W3C Decentralized Identifiers)",
