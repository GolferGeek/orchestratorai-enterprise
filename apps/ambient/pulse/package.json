{
  "name": "@orchestratorai/pulse",
  "private": true,
  "version": "0.1.0",
  "description": "Pulse — Internal Ambient Automation for OrchestratorAI Enterprise",
  "workspaces": [
    "api",
    "web"
  ],
  "scripts": {
    "dev:api": "npm run start:dev --workspace=@orchestratorai/pulse-api",
    "dev:web": "npm run dev --workspace=@orchestratorai/pulse-web",
    "dev": "concurrently -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "build:api": "npm run build --workspace=@orchestratorai/pulse-api",
    "build:web": "npm run build --workspace=@orchestratorai/pulse-web",
    "build": "npm run build:api && npm run build:web",
    "lint:api": "npm run lint --workspace=@orchestratorai/pulse-api --if-present",
    "lint:web": "npm run lint --workspace=@orchestratorai/pulse-web --if-present",
    "lint": "npm run lint:api && npm run lint:web",
    "test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.4.0"
  }
}
