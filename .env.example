# =============================================================================
# OrchestratorAI Enterprise — Environment Template
# =============================================================================
# Copy this file to .env and fill in real values.
# Put secrets in .env.secrets (gitignored). Compose loads both; .env.secrets is optional.
#
# Local Node dev: use 127.0.0.1 for Postgres / Kong below.
# Docker Compose (Nest APIs in containers): use host.docker.internal so containers reach Supabase on the host.
# =============================================================================

# --- Database (shared Supabase) ---
# Postgres: 54322; Kong REST (SUPABASE_URL): 54321 — see supabase/config.toml
#
# Local Node (npm run dev:*):
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_URL=http://127.0.0.1:54321
#
# Docker Compose (APIs in containers → host machine):
# DATABASE_URL=postgresql://postgres:postgres@host.docker.internal:54322/postgres
# SUPABASE_URL=http://host.docker.internal:54321

# --- Command (web only) ---
COMMAND_WEB_PORT=6000

# --- Auth (API only) ---
AUTH_API_PORT=6100
AUTH_API_URL=http://localhost:6100

# --- Admin (Admin API + web; Admin API is the Nest gateway for admin UI) ---
ADMIN_API_PORT=6150
ADMIN_WEB_PORT=6101

# --- Forge ---
FORGE_API_PORT=6200
FORGE_WEB_PORT=6201
FORGE_API_URL=http://localhost:6200

# --- Compose ---
COMPOSE_API_PORT=6300
COMPOSE_WEB_PORT=6301
COMPOSE_API_URL=http://localhost:6300

# --- Pulse (Ambient Internal) ---
PULSE_API_PORT=6500
PULSE_WEB_PORT=6501
PULSE_API_URL=http://localhost:6500

# --- Bridge (Ambient External) ---
BRIDGE_API_PORT=6600
BRIDGE_WEB_PORT=6601
BRIDGE_API_URL=http://localhost:6600

# --- Auth ---
JWT_EXPIRATION=3600

# --- Optional: 7xxx host ports (avoid clashing with 6xxx local Node dev) ---
# Uncomment and adjust if you publish Docker on 7xxx:
# AUTH_API_PORT=7100
# AUTH_API_URL=http://localhost:7100
# ADMIN_API_PORT=7150
# ADMIN_WEB_PORT=7101
# FORGE_API_PORT=7200
# FORGE_WEB_PORT=7201
# FORGE_API_URL=http://localhost:7200
# COMPOSE_API_PORT=7300
# COMPOSE_WEB_PORT=7301
# COMPOSE_API_URL=http://localhost:7300
# PULSE_API_PORT=7500
# PULSE_WEB_PORT=7501
# PULSE_API_URL=http://localhost:7500
# BRIDGE_API_PORT=7600
# BRIDGE_WEB_PORT=7601
# BRIDGE_API_URL=http://localhost:7600
# Rebuild web images after changing Vite-related URLs; override VITE_* for each app if needed.

# --- Docker Compose (optional) ---
# Web containers publish host:80 → map with ADMIN_WEB_PORT, COMMAND_WEB_PORT, etc.
# Vite build-time URLs for each web app can be overridden with:
# VITE_ADMIN_WEB_API_BASE_URL, VITE_COMMAND_WEB_API_BASE_URL, VITE_COMPOSE_WEB_AUTH_API_BASE_URL, VITE_FORGE_API_BASE_URL
#
# --- Cloudflare Tunnel (docker-compose.cloudflare.yml) ---
# Public URL for your Cloudflare Tunnel domain. Used by the cloudflare overlay to set
# VITE_* API URLs baked into SPAs at build time.
# CF_PUBLIC_URL=https://app.yourdomain.com
#
# --- Secrets (put these in .env.secrets, NOT here) ---
# SUPABASE_ANON_KEY=<key>
# SUPABASE_SERVICE_ROLE_KEY=<key>
# ANTHROPIC_API_KEY=<key>
# OPENAI_API_KEY=<key>
# OPENROUTER_API_KEY=<key>
# JWT_SECRET=<secret>
# STRIPE_SECRET_KEY=<key>
# STRIPE_WEBHOOK_SECRET=<key>
