# Cloudflare Tunnel credentials (keep template, ignore actual config + creds)
cloudflared/config.yml
cloudflared/*.json

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
dev-debug.log

# Database dumps and temporary files
data_dump.sql
*.dump.sql

# Supabase CLI working directories (except backups baseline and config)
/supabase/*
!/supabase/config.toml
!/supabase/backups/
/supabase/backups/archive/

# Automated backup output (cron-generated, not needed in repo)
storage/backups/
supabase/backups/local-volume-recovery/

# Dependency directories
node_modules/

# Environment variables (ignore actual files, allow examples)
/.env
/.env.local
/.env.development
/.env.backup
/.env.azure
/.env.gcp

# Secrets files (actual API keys — NEVER commit)
/.env.secrets
/.env.secrets.azure
/.env.secrets.gcp
**/.env.secrets
**/.env.secrets.*
!**/.env.secrets.example

# Explicitly allow example files
!/.env.example
!/.env.secrets.example

# Editor directories and files
.idea
.vscode
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS specific
.DS_Store

# Build artifacts
.turbo/
**/dist/

# Test coverage reports
coverage/

# Allow .env.example files everywhere (templates, not secrets)
!.env.example
!**/.env.example

# TaskMaster files
.taskmaster/

# Playwright screenshots and test artifacts
test-results/
playwright-report/
playwright/.cache/

# Monitoring artifacts
.monitor/

# Git worktrees
worktrees/

# Terraform
**/.terraform/
*.tfstate
*.tfstate.backup
*.tfplan
tfplan
terraform.tfvars
.terraform.lock.hcl

# Local bench secrets
docs/efforts/current/bench/.token
